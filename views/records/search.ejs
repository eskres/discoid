<table class="table table-striped">
    <tr>
        <th>Artwork</th>
        <th>Title</th>
        <th>Artist</th>
        <th>Release Date</th>
        <th></th>
    </tr>
<% data.releases.forEach(function(release) {
    const artist = release['artist-credit']?.[0]?.artist?.name ?? 'Unknown';
    const hasCover = release['cover-art-archive']?.front;
    const coverUrl = hasCover ? `https://coverartarchive.org/release/${release.id}/front-250` : null;
%>
    <tr>
        <td><% if (coverUrl) { %><img src="<%= coverUrl %>" alt="Album cover" width="50px" /><% } %></td>
        <td><%= release.title %></td>
        <td><%= artist %></td>
        <td><%= release.date ?? '' %></td>
        <td>
            <a href="/records/sell?title=<%= encodeURIComponent(release.title) %>&artist=<%= encodeURIComponent(artist) %>&releaseDate=<%= release.date ?? '' %>&albumCover=<%= encodeURIComponent(coverUrl) %>">SELECT</a>
        </td>
    </tr>
<% }) %>
</table>

<%
    const offset = data.offset ?? 0;
    const limit = 20;
    const total = data['release-count'] ?? 0;
    const prevOffset = offset - limit;
    const nextOffset = offset + limit;
%>

<% if(prevOffset >= 0) { %>
<form action="/records/prev" method="post">
    <input type="hidden" name="query" value="<%= query %>">
    <input type="hidden" name="offset" value="<%= prevOffset %>">
    <button type="submit" class="btn btn-primary">Prev</button>
</form>
<% } %>

<% if(nextOffset < total) { %>
<form action="/records/next" method="post">
    <input type="hidden" name="query" value="<%= query %>">
    <input type="hidden" name="offset" value="<%= nextOffset %>">
    <button type="submit" class="btn btn-primary">Next</button>
</form>
<% } %>
